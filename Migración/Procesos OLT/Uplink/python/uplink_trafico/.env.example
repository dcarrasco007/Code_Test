# ── Base de datos Aden ──────────────────────────────────────────────────────
# Copiar este archivo como .env y completar los valores reales.
# NUNCA versionar el .env real.
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASS=
DB_NAME=Aden
DB_CHARSET=utf8

# ── Rutas (opcional) ────────────────────────────────────────────────────────
# Si se omiten, se calculan automáticamente desde la raíz del proyecto.
# Útil para apuntar los logs a un directorio distinto en producción.
# LOGS_DIR=/ruta/absoluta/a/logs

# ── Parámetros de proceso (opcional) ────────────────────────────────────────
# Si se omiten, se usan los valores por defecto definidos en config/settings.py.
# MODELO_OLT=MA5800-X15
